@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>Third Task</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="MyraStudio" name="author" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- App css -->
    <link href="~/Dashboard/html/pages/assets/css/bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Dashboard/html/pages/assets/css/icons.min.css" rel="stylesheet" type="text/css" />
    <link href="~/Dashboard/html/pages/assets/css/theme.min.css" rel="stylesheet" type="text/css" />

</head>


<body>

    <div>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex align-items-center min-vh-100">
                        <div class="w-100 d-block bg-white shadow-lg rounded my-5">
                            <div class="row" style="flex-direction:column;align-items:center;">
                                <div class="col-lg-7">
                                    <div class="p-5">
                                        <div class="text-center mb-5">
                                            <a href="/Product/Index/" class="text-dark font-size-22 font-family-secondary">
                                                <b>THIRD TASK</b>
                                            </a>
                                        </div>

                                        <div class="text-center">
                                            <img src="~/Dashboard/html/pages/assets/images/404-error.svg" alt="error" height="140">
                                            <h1 class="h4 mb-3 mt-4">Page Not Found</h1>
                                            <p class="text-muted mb-4 w-75 m-auto">It's looking like you may have taken a wrong turn. Don't worry... it happens to the best of us. Here's a little tip that might help you get back on track.</p>
                                        </div>

                                        <div class="row mt-4">
                                            <div class="col-12 text-center">
                                                <a href="/Product/Index/" class="btn btn-success waves-effect waves-light"><i class="mdi mdi-home mr-2"></i>Back to Home </a>
                                            </div> <!-- end col -->
                                        </div>
                                        <!-- end row -->
                                    </div> <!-- end .padding-5 -->
                                </div> <!-- end col -->
                            </div> <!-- end row -->
                        </div> <!-- end .w-100 -->
                    </div> <!-- end .d-flex -->
                </div> <!-- end col-->
            </div> <!-- end row -->
        </div>
        <!-- end container -->
    </div>
    <!-- end page -->
    <!-- jQuery  -->
    <script src="~/Dashboard/html/pages/assets/js/jquery.min.js"></script>
    <script src="~/Dashboard/html/pages/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/Dashboard/html/pages/assets/js/metismenu.min.js"></script>
    <script src="~/Dashboard/html/pages/assets/js/waves.js"></script>
    <script src="~/Dashboard/html/pages/assets/js/simplebar.min.js"></script>

    <!-- App js -->
    <script src="~/Dashboard/html/pages/assets/js/theme.js"></script>

</body>

</html>